# Copy this file to .home-deploy/local.env and fill secrets locally.
# Do not commit .home-deploy/local.env.

POSTGRES_DB=codex
POSTGRES_USER=codex
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_PORT=5432
CODEX_CLI_DATABASE_URL=postgresql+asyncpg://codex:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/codex

CODEX_CLI_TRANSCRIPT_MINIO_ENDPOINT=127.0.0.1:9000
CODEX_CLI_TRANSCRIPT_MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
CODEX_CLI_TRANSCRIPT_MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
CODEX_CLI_TRANSCRIPT_MINIO_BUCKET=raw
CODEX_CLI_TRANSCRIPT_MINIO_PREFIX=youtube/transcripts
CODEX_CLI_TRANSCRIPT_MINIO_SECURE=false
CODEX_CLI_EXTERNAL_API_CALL_MINIO_PREFIX=external-api-calls

CODEX_CLI_MODEL=gpt-5.5
CODEX_CLI_REASONING_EFFORT=medium
CODEX_CLI_SANDBOX=workspace-write
CODEX_CLI_APPROVAL=auto-review
CODEX_CLI_PIPELINE_SCHEDULER_ENABLED=true
CODEX_CLI_PIPELINE_SCHEDULER_POLL_INTERVAL_SECONDS=300
CODEX_CLI_PIPELINE_SCHEDULER_CHANNEL_INTERVAL_SECONDS=7200
CODEX_CLI_PIPELINE_SCHEDULER_TRANSCRIPT_FALLBACK_GRACE_SECONDS=21600
CODEX_CLI_PIPELINE_SCHEDULER_TRANSCRIPT_RECHECK_INTERVAL_SECONDS=1800
CODEX_CLI_PIPELINE_SCHEDULER_TRANSCRIPT_LIMIT=5
CODEX_CLI_PIPELINE_SCHEDULER_NO_TRANSCRIPT_RECHECK_INTERVAL_SECONDS=604800
CODEX_CLI_PIPELINE_SCHEDULER_NO_TRANSCRIPT_LIMIT=2
CODEX_CLI_PIPELINE_SCHEDULER_WORKFLOW_LIMIT=12
CODEX_CLI_PIPELINE_SUPERVISOR_ENABLED=true
CODEX_CLI_PIPELINE_SUPERVISOR_POLL_INTERVAL_SECONDS=60
CODEX_CLI_MICRO_EVENT_EXTRACT_CONCURRENCY_LIMIT=1
CODEX_CLI_MICRO_EVENT_WINDOW_CONCURRENCY_LIMIT=6
CODEX_CLI_TRANSCRIPT_WORKER_POLL_INTERVAL_SECONDS=5
CODEX_CLI_TRANSCRIPT_CUE_WORKER_POLL_INTERVAL_SECONDS=5
CODEX_CLI_ASR_TRANSCRIBE_CONCURRENCY_LIMIT=1
CODEX_CLI_ASR_TRANSCRIBE_TIMEOUT_SECONDS=64800
CODEX_CLI_ASR_WORKER_POLL_INTERVAL_SECONDS=5
CODEX_CLI_MICRO_EVENT_WORKER_POLL_INTERVAL_SECONDS=5
CODEX_CLI_TIMELINE_COMPOSE_WORKER_POLL_INTERVAL_SECONDS=5
CODEX_CLI_WORKFLOW_COORDINATOR_POLL_INTERVAL_SECONDS=5

# Required while CODEX_CLI_PIPELINE_SCHEDULER_ENABLED=true. If this key is not
# configured, set CODEX_CLI_PIPELINE_SCHEDULER_ENABLED=false to avoid failed ticks.
# CODEX_CLI_YOUTUBE_DATA_API_KEY=

# Optional:
# CODEX_CLI_API_KEY=
# CODEX_CLI_YOUTUBE_HTTP_PROXY=
# CODEX_CLI_YOUTUBE_HTTPS_PROXY=
# CODEX_CLI_ARCHIVE_PUBLISH_R2_ENDPOINT=
# CODEX_CLI_ARCHIVE_PUBLISH_R2_ACCESS_KEY=
# CODEX_CLI_ARCHIVE_PUBLISH_R2_SECRET_KEY=
# CODEX_CLI_ARCHIVE_PUBLISH_R2_BUCKET=
# CODEX_CLI_ARCHIVE_PUBLISH_PUBLIC_BASE_URL=
# CODEX_CLI_ARCHIVE_PUBLISH_DEV_R2_BUCKET=
# CODEX_CLI_ARCHIVE_PUBLISH_DEV_PUBLIC_BASE_URL=
# CODEX_CLI_ARCHIVE_PUBLIC_CATALOG_SYNC_ENABLED=true
# CODEX_CLI_ARCHIVE_PUBLIC_CATALOG_SYNC_URL=https://<pages-domain>/api/admin/archive/videos/upsert
# CODEX_CLI_ARCHIVE_PUBLIC_CATALOG_SYNC_TOKEN=
# CODEX_CLI_ARCHIVE_PUBLIC_CATALOG_SYNC_TIMEOUT_SECONDS=15

CODEX_OPS_BACKEND_BASE_URL=http://127.0.0.1:8000
HOSTNAME=127.0.0.1
PORT=3000
